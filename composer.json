{
    "name": "mulertech/green-daily",
    "type": "project",
    "license": "proprietary",
    "description": "Vegetarian nutrient tracker (personal use)",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.4.1",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "doctrine/dbal": "^4.4",
        "doctrine/doctrine-bundle": "^3.2",
        "doctrine/doctrine-migrations-bundle": "^3.7",
        "doctrine/orm": "^3.6.7",
        "league/commonmark": "^2.8",
        "mulertech/csp-bundle": ">=2.0.1",
        "phpoffice/phpspreadsheet": "^5.0",
        "symfony/asset": "8.1.*",
        "symfony/asset-mapper": "8.1.*",
        "symfony/console": "8.1.*",
        "symfony/doctrine-messenger": "8.1.*",
        "symfony/dotenv": "8.1.*",
        "symfony/flex": "^2.11",
        "symfony/form": "8.1.*",
        "symfony/framework-bundle": "8.1.*",
        "symfony/http-client": "8.1.*",
        "symfony/intl": "8.1.*",
        "symfony/mailer": "8.1.*",
        "symfony/messenger": "8.1.*",
        "symfony/mime": "8.1.*",
        "symfony/monolog-bundle": "^4.0.2",
        "symfony/property-access": "8.1.*",
        "symfony/property-info": "8.1.*",
        "symfony/rate-limiter": "8.1.*",
        "symfony/runtime": "8.1.*",
        "symfony/security-bundle": "8.1.*",
        "symfony/serializer": "8.1.*",
        "symfony/string": "8.1.*",
        "symfony/translation": "8.1.*",
        "symfony/twig-bundle": "8.1.*",
        "symfony/validator": "8.1.*",
        "symfony/yaml": "8.1.*",
        "symfonycasts/reset-password-bundle": "^1.24",
        "symfonycasts/tailwind-bundle": "^0.13",
        "twig/extra-bundle": "^3.22",
        "twig/intl-extra": "*",
        "twig/markdown-extra": "^3.23",
        "twig/twig": "^3.27.1"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.95.4",
        "mulertech/docker-dev": ">=3.3",
        "phpstan/extension-installer": "*",
        "phpstan/phpstan": "^2.2.1",
        "phpstan/phpstan-doctrine": ">=2.0.25",
        "phpstan/phpstan-symfony": ">=2.0.19",
        "phpunit/phpunit": "^11.5",
        "symfony/browser-kit": "8.1.*",
        "symfony/css-selector": "8.1.*",
        "symfony/debug-bundle": "8.1.*",
        "symfony/maker-bundle": "^1.62",
        "symfony/phpunit-bridge": "8.1.*",
        "symfony/stopwatch": "8.1.*",
        "symfony/web-profiler-bundle": "8.1.*"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true,
            "phpstan/extension-installer": true
        },
        "bump-after-update": true,
        "sort-packages": true,
        "platform": {
            "php": "8.4.21"
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "importmap:install": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "8.1.*"
        }
    }
}
