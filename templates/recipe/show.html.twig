{% extends 'base.html.twig' %}

{% block title %}Recette suggérée — Green Daily{% endblock %}

{% block body %}
    <main class="mx-auto max-w-md px-4 py-6">
        <header class="mb-6 flex items-center gap-3">
            <a href="{{ path('app_home') }}" class="text-slate-500 hover:text-slate-700">←</a>
            <h1 class="text-xl font-bold text-emerald-700">Recette suggérée</h1>
        </header>

        {% if not suggestion.ok %}
            <div class="rounded-lg bg-red-50 px-4 py-3 text-sm text-red-700">
                {{ suggestion.responseMarkdown }}
            </div>
        {% else %}
            <article class="prose prose-slate prose-sm max-w-none rounded-lg bg-white px-5 py-4 shadow-sm">
                {{ suggestion.responseMarkdown|markdown_to_html }}
            </article>
        {% endif %}

        <p class="mt-6 text-center text-sm">
            <a href="{{ path('app_home') }}" class="text-emerald-700 hover:underline">← Retour au dashboard</a>
        </p>
    </main>
{% endblock %}
