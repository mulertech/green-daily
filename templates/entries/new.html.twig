{% extends 'base.html.twig' %}

{% block title %}Ajouter un aliment — Green Daily{% endblock %}

{% block importmap %}{{ importmap(['app', 'foods-search'], {nonce: csp_nonce('main')}) }}{% endblock %}

{% block body %}
    <main class="mx-auto max-w-md px-4 py-6">
        <header class="mb-6 flex items-center gap-3">
            <a href="{{ path('app_home') }}" class="text-slate-500 hover:text-slate-700">←</a>
            <h1 class="text-xl font-bold text-emerald-700">Ajouter un aliment</h1>
        </header>

        {% if errors is not empty %}
            <div class="mb-4 rounded-lg bg-red-50 px-4 py-3 text-sm text-red-700">
                <ul class="list-disc pl-5">
                    {% for e in errors %}<li>{{ e }}</li>{% endfor %}
                </ul>
            </div>
        {% endif %}

        <form method="post" class="space-y-4">
            <input type="hidden" name="_token" value="{{ csrf_token('new-entry') }}">
            <input type="hidden" name="food_id" id="food_id" value="{{ food_id ?: '' }}">

            <div class="relative">
                <label for="food_query" class="mb-1 block text-sm font-medium text-slate-700">Aliment</label>
                <input type="text" id="food_query" name="food_query"
                       value="{{ food_query }}" autocomplete="off" required autofocus
                       placeholder="Tapez au moins 2 lettres…"
                       data-foods-search="{{ path('api_foods_search') }}"
                       data-hidden-name="food_id"
                       data-dropdown-id="foods-dropdown"
                       class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-base shadow-sm focus:border-emerald-500 focus:ring-2 focus:ring-emerald-200 focus:outline-none">
                <ul id="foods-dropdown"
                    class="absolute left-0 right-0 z-20 mt-1 hidden max-h-72 overflow-y-auto rounded-lg border border-slate-200 bg-white shadow-lg"></ul>
            </div>

            <div>
                <label for="quantity_grams" class="mb-1 block text-sm font-medium text-slate-700">Quantité (g)</label>
                <input type="number" id="quantity_grams" name="quantity_grams" min="1" max="5000" step="1"
                       inputmode="numeric" value="{{ quantity }}" required
                       class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-base shadow-sm focus:border-emerald-500 focus:ring-2 focus:ring-emerald-200 focus:outline-none">
            </div>

            <button type="submit" name="action" value="add"
                    class="w-full rounded-lg bg-emerald-600 px-4 py-2.5 text-base font-medium text-white shadow-sm transition hover:bg-emerald-700">
                Ajouter
            </button>
            <button type="submit" name="action" value="preview" formnovalidate
                    class="w-full rounded-lg border border-emerald-300 bg-white px-4 py-2.5 text-base font-medium text-emerald-700 shadow-sm transition hover:bg-emerald-50">
                Voir les apports
            </button>
        </form>

        {% if preview %}
            <section class="mt-6 rounded-lg bg-white px-4 py-4 shadow-sm">
                <h2 class="text-sm font-semibold text-slate-800">Apports — {{ preview.food }}</h2>
                <p class="mb-3 text-xs text-slate-500">Pour {{ preview.quantity|number_format(0, ',', ' ') }} g</p>

                {% if preview.rows is empty %}
                    <p class="text-sm text-slate-500">Aucune donnée d'apport disponible pour cet aliment.</p>
                {% else %}
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="border-b border-slate-200 text-left text-xs uppercase tracking-wide text-slate-400">
                                <th class="py-1.5 font-medium">Nutriment</th>
                                <th class="py-1.5 text-right font-medium">Apport</th>
                                <th class="py-1.5 text-right font-medium">% AJR</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for row in preview.rows %}
                                <tr class="border-b border-slate-100 last:border-0">
                                    <td class="py-1.5 text-slate-700">{{ row.label }}</td>
                                    <td class="py-1.5 text-right text-slate-700">
                                        {{ row.amount|number_format(row.amount < 10 ? 2 : 1, ',', ' ') }} {{ row.unit }}
                                    </td>
                                    <td class="py-1.5 text-right font-medium text-emerald-700">
                                        {{ row.percent is not null ? row.percent ~ ' %' : '—' }}
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                    <p class="mt-3 text-xs text-slate-400">
                        % AJR = part de l'apport journalier recommandé pour votre profil.
                    </p>
                {% endif %}
            </section>
        {% endif %}
    </main>
{% endblock %}
